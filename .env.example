# Turso / libSQL
TURSO_DATABASE_URL=libsql://tu-base.turso.io
TURSO_AUTH_TOKEN=tu_token_de_turso

# Login del panel admin (usa UNA de las dos opciones)
# Opción simple: contraseña en texto
ADMIN_PASSWORD=cambia-esta-clave
# Opción segura: hash bcrypt (genera con `node scripts/hash-password.mjs "tuClave"`)
# ADMIN_PASSWORD_HASH=

# Secreto para firmar los JWT del admin
JWT_SECRET=una_cadena_larga_y_aleatoria

# Base pública del sitio (para generar los links en el importador)
SITE_URL=https://boda.linareschacon.com
